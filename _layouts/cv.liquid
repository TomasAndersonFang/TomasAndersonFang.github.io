---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {{ page.title }}
      {% if page.cv_pdf %}
        <a
          href="{{ page.cv_pdf | prepend: 'assets/pdf/' | relative_url}}"
          target="_blank"
          rel="noopener noreferrer"
          class="float-right"
          ><i class="fa-solid fa-file-pdf"></i
        ></a>
      {% endif %}
    </h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    <div class="cv">
      <iframe
        id="cv-iframe"
        src="{{ 'assets/html/Sen_Fang_CV.html' | relative_url }}"
        style="width: 100%; border: none; overflow: hidden;"
        scrolling="no"
        title="Sen Fang CV"
      ></iframe>
      <script>
        // Auto-resize iframe to fit content
        function resizeCvIframe() {
          var iframe = document.getElementById('cv-iframe');
          if (iframe && iframe.contentDocument) {
            iframe.style.height = iframe.contentDocument.documentElement.scrollHeight + 'px';
          }
        }
        document.getElementById('cv-iframe').addEventListener('load', resizeCvIframe);
        window.addEventListener('resize', resizeCvIframe);
      </script>
    </div>
  </article>
</div>
